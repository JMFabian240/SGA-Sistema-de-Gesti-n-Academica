@startuml
left to right direction
skinparam packageStyle rectangle

actor "Administrador" as Actor
boundary "UsuariosListPage\n(Tabla)" as UI_List
boundary "RolesModal\n(Modal)" as UI_Modal
control "UsuariosController\n(tRPC Router)" as Router
entity "Rol / UsuarioRol\n(PostgreSQL)" as BD

Actor --> UI_List : Clic en "Gestionar Roles"
UI_List --> UI_Modal : Abre modal
UI_Modal --> Router : getRoles()
Router --> BD : findMany(Rol)
BD --> Router : Catalogo Roles
Router --> UI_Modal : Renderiza Checkboxes

Actor --> UI_Modal : Modifica checks y "Guardar"
UI_Modal --> Router : asignarRoles(usuarioId, roles[])
Router --> BD : $transaction(delete, create)
BD --> Router : Éxito
Router --> UI_Modal : OK
UI_Modal --> UI_List : Cierra modal y recarga lista
@enduml
