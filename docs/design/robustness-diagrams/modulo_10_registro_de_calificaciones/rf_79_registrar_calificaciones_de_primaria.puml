@startuml
left to right direction
skinparam packageStyle rectangle
actor "Docente" as Docente
boundary "Pantalla Calificaciones" as Pantalla
control "Gestor Notas" as Gestor
entity "Historial Académico" as BDAcademico
Docente --> Pantalla : Captura notas Primaria
Pantalla --> Gestor : Envía bloque de calificaciones
Gestor --> BDAcademico : Valida escala (5-10) y guarda
BDAcademico --> Gestor : Confirma
Gestor --> Pantalla : Muestra éxito
Pantalla --> Docente : Notifica guardado
@enduml
