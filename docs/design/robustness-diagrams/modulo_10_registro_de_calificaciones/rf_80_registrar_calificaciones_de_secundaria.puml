@startuml
left to right direction
skinparam packageStyle rectangle
actor "Docente" as Docente
boundary "Pantalla Calificaciones" as Pantalla
control "Gestor Notas" as Gestor
entity "Historial Académico" as BDAcademico
Docente --> Pantalla : Captura notas Secundaria
Pantalla --> Gestor : Envía evaluaciones por materia
Gestor --> BDAcademico : Valida y persiste
BDAcademico --> Gestor : Confirma
Gestor --> Pantalla : Retorna estado
Pantalla --> Docente : Notifica guardado
@enduml
